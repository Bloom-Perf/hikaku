{
  "name": "@bloom-perf/hikaku",
  "version": "0.2.1",
  "description": "Lightweight Prometheus metrics analysis and regression detection for Kyara load testing",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0",
    "prom-client": "^15.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0 || ^0.80.0",
    "@types/chai": "5.2.3",
    "@types/mocha": "10.0.10",
    "c8": "11.0.0",
    "chai": "6.2.2",
    "esbuild": "0.27.4",
    "esbuild-node-externals": "1.20.1",
    "mocha": "11.7.5",
    "prettier": "3.8.3",
    "prom-client": "15.1.3",
    "ts-node": "10.9.2",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  },
  "scripts": {
    "build": "rm -rf dist && node esbuild.js && tsc -p tsconfig.build.json",
    "test": "mocha",
    "test:coverage": "c8 npm run test",
    "format": "prettier --write src/ test/",
    "format:check": "prettier --check src/ test/"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bloom-Perf/hikaku.git"
  },
  "keywords": [
    "prometheus",
    "metrics",
    "baseline",
    "regression",
    "load-testing",
    "performance",
    "llm",
    "report"
  ],
  "author": "Bloom-perf",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/Bloom-Perf/hikaku/issues"
  },
  "homepage": "https://www.npmjs.com/package/@bloom-perf/hikaku"
}
